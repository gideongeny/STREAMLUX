rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users can only read/write their own data
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;
      
      // Allow users to sync their watch progress securely
      match /watchProgress/{mediaId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
    
    // Comments & Replies (Unified Structure)
    match /comments/{commentId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }
    
    // Legacy support for dynamic comment paths (Should be migrated if possible)
    match /{path=**}/comments/{commentId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
        allow update, delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }

    // LiveBuzz (Real-time Reactions)
    match /livebuzz/{docId} {
      // Anyone authenticated can read the reactions
      allow read: if request.auth != null;
      // Anyone authenticated can add a reaction (via arrayUnion)
      allow write: if request.auth != null;
    }

    // User Ratings
    match /user_ratings/{ratingId} {
      allow read: if true; // Ratings can be public
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }

    // Content Requests
    match /requests/{requestId} {
      allow read: if false; // Only admins via console should read
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow update, delete: if false;
    }
    
    // Bookmarks - users can only access their own
    match /bookmarks/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Watch history - users can only access their own
    match /watchHistory/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Deny all other access by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
