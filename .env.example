# Frontend (Vite)
#
# IMPORTANT:
# - Never commit real keys. Copy this to `.env` locally.
# - Vite exposes `VITE_*` variables to the browser, so only put **non-secret** values here.

# Optional override for where the app should consider "origin" (useful for Capacitor builds).
# Default: window.location.origin
VITE_APP_ORIGIN=

# Optional UX
VITE_BMC_USERNAME=gideongeny

# Firebase web config (not secret, but keep it configurable)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=streamlux-67a84
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
