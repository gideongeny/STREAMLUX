{
  "functions": {
    "api/proxy/*.ts": {
      "runtime": "nodejs18.x"
    }
  },
  "buildCommand": "CI=false npm install --force --legacy-peer-deps && CI=false npm run build",
  "outputDirectory": "build",
  "installCommand": "npm install --force --legacy-peer-deps --no-optional",
  "devCommand": "npm start",
  "rewrites": [
    {
      "source": "/api/proxy/tmdb",
      "destination": "/api/tmdb"
    },
    {
      "source": "/api/proxy/tmdb/(.*)",
      "destination": "/api/tmdb?endpoint=/$1"
    },
    {
      "source": "/api/proxy/youtube",
      "destination": "/api/youtube"
    },
    {
      "source": "/api/proxy/youtube/(.*)",
      "destination": "/api/youtube?endpoint=/$1"
    },
    {
      "source": "/api/proxy/external",
      "destination": "/api/external"
    },
    {
      "source": "/api/proxy/external/(.*)",
      "destination": "/api/external?endpoint=/$1"
    },
    {
      "source": "/api/scrapers",
      "destination": "/api/scrapers.ts"
    },
    {
      "source": "/api/health",
      "destination": "/api/health.ts"
    },
    {
      "source": "/((?!api|.*\\.apk$).*)",
      "destination": "/index.html"
    }
  ]
}