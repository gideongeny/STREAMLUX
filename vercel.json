{
  "buildCommand": "CI=false npm install --force --legacy-peer-deps && CI=false npm run build",
  "outputDirectory": "build",
  "installCommand": "npm install --force --legacy-peer-deps --no-optional",
  "devCommand": "npm start",
  "rewrites": [
    {
      "source": "/api/proxy/tmdb",
      "destination": "/api/proxy/tmdb.ts"
    },
    {
      "source": "/api/proxy/tmdb/(.*)",
      "destination": "/api/proxy/tmdb.ts?endpoint=/$1"
    },
    {
      "source": "/api/proxy/youtube",
      "destination": "/api/proxy/youtube.ts"
    },
    {
      "source": "/api/proxy/youtube/(.*)",
      "destination": "/api/proxy/youtube.ts?endpoint=/$1"
    },
    {
      "source": "/api/proxy/external",
      "destination": "/api/proxy/external.ts"
    },
    {
      "source": "/api/proxy/external/(.*)",
      "destination": "/api/proxy/external.ts?endpoint=/$1"
    },
    {
      "source": "/api/scrapers",
      "destination": "/api/scrapers.ts"
    },
    {
      "source": "/api/health",
      "destination": "/api/health.ts"
    },
    {
      "source": "/((?!api|.*\\.apk$).*)",
      "destination": "/index.html"
    }
  ]
}