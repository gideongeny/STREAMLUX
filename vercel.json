{
  "buildCommand": "CI=false npm install --force --legacy-peer-deps && CI=false npm run build",
  "outputDirectory": "build",
  "installCommand": "npm install --force --legacy-peer-deps --no-optional",
  "rewrites": [
    {
      "source": "/api/proxy/tmdb",
      "destination": "https://streamlux-67a84.web.app/api/proxy/tmdb"
    },
    {
      "source": "/api/proxy/tmdb/(.*)",
      "destination": "https://streamlux-67a84.web.app/api/proxy/tmdb/$1"
    },
    {
      "source": "/api/proxy/youtube",
      "destination": "https://streamlux-67a84.web.app/api/proxy/youtube"
    },
    {
      "source": "/api/proxy/youtube/(.*)",
      "destination": "https://streamlux-67a84.web.app/api/proxy/youtube/$1"
    },
    {
      "source": "/api/proxy/external",
      "destination": "https://streamlux-67a84.web.app/api/proxy/external"
    },
    {
      "source": "/api/proxy/external/(.*)",
      "destination": "https://streamlux-67a84.web.app/api/proxy/external/$1"
    },
    {
      "source": "/api/resolve",
      "destination": "https://streamlux-67a84.web.app/api/resolve"
    },
    {
      "source": "/api/scrapers/resolve",
      "destination": "https://streamlux-67a84.web.app/api/scrapers/resolve"
    },
    {
      "source": "/((?!api|.*\\.apk$).*)",
      "destination": "/index.html"
    }
  ]
}