{
  "buildCommand": "CI=false npm install --force --legacy-peer-deps && CI=false npm run build",
  "outputDirectory": "build",
  "installCommand": "npm install --force --legacy-peer-deps --no-optional",
  "rewrites": [
    {
      "source": "/api/proxy/tmdb",
      "destination": "/api/tmdb.js"
    },
    {
      "source": "/api/proxy/tmdb/(.*)",
      "destination": "/api/tmdb.js?endpoint=/$1"
    },
    {
      "source": "/api/proxy/youtube",
      "destination": "/api/youtube.js"
    },
    {
      "source": "/api/proxy/youtube/(.*)",
      "destination": "/api/youtube.js?endpoint=/$1"
    },
    {
      "source": "/api/proxy/external",
      "destination": "/api/external.js"
    },
    {
      "source": "/api/proxy/external/(.*)",
      "destination": "/api/external.js?endpoint=/$1"
    },
    {
      "source": "/api/health",
      "destination": "/api/health.js"
    },
    {
      "source": "/((?!api|.*\\.apk$).*)",
      "destination": "/index.html"
    }
  ]
}