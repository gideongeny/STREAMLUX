# Firebase Functions runtime env
#
# DO NOT COMMIT `.env` with real secrets.
# Use Firebase Secrets/Env in production; `.env` is for local emulators.

# TMDB
TMDB_API_KEY=
TMDB_BEARER_TOKEN=

# YouTube (comma-separated API keys)
YT_KEYS=

# Sports APIs
SPORTMONKS_KEY=
APISPORTS_KEY=
SCOREBAT_TOKEN=

# Third-party proxies used by the frontend (keep server-side)
OMDB_API_KEY=
WATCHMODE_API_KEY=
RAPIDAPI_KEY=
